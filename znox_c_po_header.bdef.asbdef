projection;
strict ( 2 );
use draft;

// Projection behavior for Header
define behavior for ZNOX_C_PO_HEADER alias Header
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Items { create; with draft; }
}

// Projection behavior for Item
define behavior for ZNOX_C_PO_ITEM alias Item
{
  use update;
  use delete;

  use association _Header { with draft; }
}
